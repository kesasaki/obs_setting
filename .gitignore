# OBSの自動生成・一時ファイルを除外
logs/
crashes/
plugin_config/*/cache/
# obs-browserはChromiumエンジンデータ。LocalPrefs.jsonのみ追跡
plugin_config/obs-browser/*
!plugin_config/obs-browser/LocalPrefs.json
updates/
**/*.json.bak
**/*.bak
**/*.v1

# obs-localvocalのAIモデル（巨大バイナリ、数GB）
plugin_config/obs-localvocal/models/

# 機密情報（ストリームキー・パスワード等）が含まれるファイルを除外
**/service.json
**/history.json
**/streamEncoder.json
plugin_config/obs-websocket/config.json
profiler_data/
