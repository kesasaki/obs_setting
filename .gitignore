# OBSの自動生成・一時ファイルを除外
logs/
crashes/
plugin_config/*/cache/
# obs-browserはChromiumエンジンデータ（自動生成）。すべて除外
plugin_config/obs-browser/*
updates/
**/*.json.bak
**/*.bak
**/*.v1

# obs-localvocalのAIモデル（巨大バイナリ、数GB）
plugin_config/obs-localvocal/models/

# 機密情報（ストリームキー・パスワード等）が含まれるファイルを除外
**/service.json
**/history.json
**/streamEncoder.json
plugin_config/obs-websocket/config.json
profiler_data/
**/basic.ini
user.ini
